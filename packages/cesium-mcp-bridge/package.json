{
  "name": "cesium-mcp-bridge",
  "version": "1.139.6",
  "description": "Cesium MCP Bridge SDK — AI Agent 操控 Cesium 的统一执行层",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "cesium": "~1.139.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "cesium": "^1.114.0"
  },
  "keywords": [
    "cesium",
    "mcp",
    "model-context-protocol",
    "gis",
    "ai-agent",
    "3d-visualization",
    "bridge",
    "websocket",
    "cesiumjs",
    "geospatial"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gaopengbin/cesium-mcp.git",
    "directory": "packages/cesium-mcp-bridge"
  },
  "homepage": "https://github.com/gaopengbin/cesium-mcp/tree/main/packages/cesium-mcp-bridge",
  "license": "MIT"
}
